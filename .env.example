# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Tamarind Bio API
TAMARIND_API_KEY=your_tamarind_api_key_here
TAMARIND_API_BASE_URL=https://app.tamarind.bio/api/

# Redis
REDIS_URL=redis://localhost:6379/0

# Modal
MODAL_TOKEN_ID="your_modal_token_id_here"
MODAL_TOKEN_SECRET="your_modal_token_secret_here"
MODAL_APP_NAME=biosync-orchestrator

# PostgreSQL (apps/api)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bioos

# Auth (apps/api) — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here

# App
APP_ENV=development
LOG_LEVEL=INFO

